# -----------------------------------------------------------------------------
# .env.example — local/dev stack only (docker-compose.yml)
#
# Copy to .env (which IS gitignored) and fill in real values.
# DO NOT commit real secrets.
# -----------------------------------------------------------------------------

# MySQL root password (used only by the mysql container at init time)
MYSQL_ROOT_PASSWORD=change-me-root

# Application database + credentials (used by BOTH containers)
MYSQL_DB=todos
MYSQL_USER=todo
MYSQL_PASSWORD=change-me-app
