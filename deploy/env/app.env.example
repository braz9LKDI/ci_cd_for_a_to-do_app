# -----------------------------------------------------------------------------
# deploy/env/app.env.example
#
# Template for /opt/deploy/env/app.env on the Vagrant VM.
# Consumed by the `app` service in docker-compose.deploy.yml.
#
# On the VM, create /opt/deploy/env/app.env with chmod 0600 and owner `vagrant`.
# MYSQL_HOST is intentionally NOT listed here — the compose file hardcodes it
# to the service name `mysql` to prevent accidental override.
# -----------------------------------------------------------------------------

MYSQL_DB=todos
MYSQL_USER=todo
MYSQL_PASSWORD=REPLACE_ME
