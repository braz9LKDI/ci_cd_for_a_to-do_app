# ---------------------------------------------------------------------------
# Example environment file for the Vagrant scaffold.
#
# Copy to `.env` (which IS gitignored) and adjust. None of these are
# required — all have sane defaults inside the Vagrantfile.
# ---------------------------------------------------------------------------

# --- Vagrant / VM --------------------------------------------------------
# Base box (Ubuntu). Change if your chosen provider requires a different box.
VAGRANT_BOX=generic/ubuntu2204

# VM identity
VAGRANT_HOSTNAME=deploy-target

# Resources
VAGRANT_CPUS=2
VAGRANT_MEMORY=2048

# Synced folder configuration
VAGRANT_SYNC_HOST=../../
VAGRANT_SYNC_GUEST=/vagrant-project
# Set to "true" to disable folder sync entirely (useful on Hyper-V before SMB is set up)
VAGRANT_SYNC_DISABLED=false

# --- Provider selection --------------------------------------------------
# Uncomment ONE once you have chosen:
# VAGRANT_DEFAULT_PROVIDER=virtualbox
# VAGRANT_DEFAULT_PROVIDER=hyperv

# --- Hyper-V SMB credentials (only if you enable SMB sync) ---------------
# Do NOT commit real values.
# VAGRANT_SMB_USER=
# VAGRANT_SMB_PASS=

# --- CircleCI (placeholders — NOT used yet) ------------------------------
# CIRCLECI_RUNNER_TOKEN=
# CIRCLECI_RUNNER_RESOURCE_CLASS=
